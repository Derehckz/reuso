# See https://help.github.com/articles/ignoring-files/

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build
/dist

# env — secretos locales (sí commitear plantilla)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local
!.env.example

# vercel / deploy
.vercel

# typescript
*.tsbuildinfo

# prisma client (se genera con postinstall / prisma generate)
/src/generated/prisma

# runtime uploads (admin)
/public/uploads/*
!/public/uploads/.gitkeep
!/public/uploads/avatars/.gitkeep
!/public/uploads/products/.gitkeep
!/public/uploads/banners/.gitkeep
!/public/uploads/categories/.gitkeep

# logs & debug
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# caches
.turbo
.swc

# OS
.DS_Store
Thumbs.db
Desktop.ini

# IDE / editor
.idea/
.vscode/
.cursor/

# certs / keys locales
*.pem

# docker overrides locales (compose base sí va al repo)
docker-compose.override.yml

# herramientas locales opcionales
.pm2/
