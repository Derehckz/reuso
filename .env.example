# Database
# Docker: docker compose up -d  →  postgresql://postgres:postgres@localhost:5432/reuso
# Prisma Dev: npx prisma dev  →  copia la URL postgres://…:51214/… que imprime el CLI (más estable que prisma+postgres en Next.js)
DATABASE_URL="postgresql://user:password@localhost:5432/reuso?schema=public"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="reuso"

# Auth.js / NextAuth
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# Google OAuth
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# MercadoPago (Checkout Pro)
# sandbox: credenciales TEST- desde https://www.mercadopago.cl/developers/panel/app
# production: credenciales APP_USR- de producción
MERCADOPAGO_ENV="sandbox"
MERCADOPAGO_ACCESS_TOKEN=""
MERCADOPAGO_PUBLIC_KEY=""
# Secret signature desde Webhooks > Configurar notificaciones en el panel MP
# Obligatorio en producción (el webhook responde 503 si falta)
MERCADOPAGO_WEBHOOK_SECRET=""

# Bluexpress / Blue Express (API agencias)
BLUEXPRESS_API_KEY=""
BLUEXPRESS_API_URL="https://apigw.bluex.cl/api"
BLUEXPRESS_ACCOUNT_ID=""
BLUEXPRESS_QUOTE_PATH="/cross/v1/quotes"
BLUEXPRESS_TRACKING_PATH="/cross/v1/tracking"
BLUEXPRESS_LABEL_PATH="/cross/v1/shipments/labels"
# Origen del despacho
BLUEXPRESS_ORIGIN_REGION="Región Metropolitana de Santiago"
BLUEXPRESS_ORIGIN_COMMUNE="Santiago"
BLUEXPRESS_ORIGIN_REGION_CODE="RM"
BLUEXPRESS_ORIGIN_NAME="reuso"
BLUEXPRESS_ORIGIN_PHONE="+56900000000"
BLUEXPRESS_ORIGIN_STREET="Santiago"

# WooCommerce → importación desde re-uso.cl (npm run import:woocommerce)
# WooCommerce → Ajustes → Avanzado → REST API → clave con permiso Lectura
WC_STORE_URL="https://re-uso.cl"
WC_CONSUMER_KEY=""
WC_CONSUMER_SECRET=""

# Cron (cancelar órdenes sin pago) — GET /api/cron/expire-orders con header Authorization: Bearer <secret>
CRON_SECRET="generate-with-openssl-rand-base64-32"

# Email (password recovery — configure your provider)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
EMAIL_FROM="hola@reuso.cl"
